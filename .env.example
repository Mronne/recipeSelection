# ==========================================
# 裕厨华餐 - 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ==========================================

# GitHub 用户名（用于镜像地址）
GITHUB_USER=yourusername

# 数据存储路径
# Synology: /volume1/docker/yus-kitchen/data
# QNAP: /share/Container/yus-kitchen/data
# Unraid: /mnt/user/appdata/yus-kitchen/data
DATA_DIR=./data

# 用户和组 ID（保持与 NAS 用户一致）
PUID=1000
PGID=1000

# 时区
TZ=Asia/Shanghai

# 是否允许注册新用户
true = 允许，false = 禁止
ALLOW_SIGNUP=true

# 外部访问地址（重要！用于生成链接）
# 修改为你的 NAS 域名或 IP
BASE_URL=http://localhost:9000

# 数据库引擎
# sqlite = SQLite（默认，适合小型部署）
# postgres = PostgreSQL（推荐用于生产环境）
DB_ENGINE=sqlite

# ==========================================
# PostgreSQL 配置（可选）
# ==========================================
# POSTGRES_USER=mealie
# POSTGRES_PASSWORD=changeme
# POSTGRES_SERVER=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=mealie

# ==========================================
# OpenAI 配置（可选，用于智能解析）
# ==========================================
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# ==========================================
# 邮件配置（可选）
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM_NAME=裕厨华餐
# SMTP_AUTH_STRATEGY=TLS
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
