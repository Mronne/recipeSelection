# ==========================================
# NAS 部署环境变量配置
# 复制此文件为 .env 并修改为你自己的配置
# ==========================================

# GitHub 用户名（用于镜像地址）
GITHUB_USER=yourusername

# NAS 数据存储路径（重要！）
# 修改为 NAS 上的实际路径，例如：
# - Synology: /volume1/docker/recipe/data
# - QNAP: /share/Container/recipe/data
# - Unraid: /mnt/user/appdata/recipe/data
NAS_DATA_PATH=./data

# 用户和组 ID（保持与 NAS 用户一致）
PUID=1000
PGID=1000

# 时区
TZ=Asia/Shanghai

# 是否允许注册新用户
true = 允许注册，false = 禁止注册
ALLOW_SIGNUP=true

# 外部访问地址（用于生成链接）
# 修改为你的 NAS 域名或 IP
BASE_URL=http://your-nas-ip:3000

# 端口配置（如果冲突可修改）
FRONTEND_PORT=3000
BACKEND_PORT=9000
